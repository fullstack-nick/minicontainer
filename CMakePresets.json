{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev-gcc",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-gcc",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "CMAKE_C_COMPILER": "gcc" }
    },
    {
      "name": "dev-clang",
      "inherits": "dev-gcc",
      "binaryDir": "${sourceDir}/build/dev-clang",
      "cacheVariables": { "CMAKE_C_COMPILER": "clang" }
    }
  ],
  "buildPresets": [
    { "name": "dev-gcc", "configurePreset": "dev-gcc" },
    { "name": "dev-clang", "configurePreset": "dev-clang" }
  ],
  "testPresets": [
    { "name": "dev-gcc", "configurePreset": "dev-gcc", "output": { "outputOnFailure": true } },
    { "name": "dev-clang", "configurePreset": "dev-clang", "output": { "outputOnFailure": true } }
  ]
}
